# Menu Management — Environment Variables

# Copy this file to .env and adjust values.
#   cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=menu_db

# Backend 
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=menu_db
SERVER_PORT=8080
APP_ENV=development

# Frontend 
VITE_API_BASE_URL=http://localhost:8080/api
